NEXT_PUBLIC_ELEVENLABS_COMPANION_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_GROUNDING_AGENT_ID=
NEXT_PUBLIC_ELEVENLABS_ESCALATION_AGENT_ID=

# ─────────────────────────────────────────
# Firecrawl
# Get this from: firecrawl.dev → Dashboard
# ─────────────────────────────────────────
FIRECRAWL_API_KEY=

# ─────────────────────────────────────────
